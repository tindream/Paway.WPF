<Page x:Class="Paway.Test.TestProgressBar"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Paway.Test"
      xmlns:model="clr-namespace:Paway.Model;assembly=Paway.Model"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
      mc:Ignorable="d" 
      UseLayoutRounding="True"
      DataContext="{Binding TestProgressBar, Source={StaticResource Locator}}"
      d:DesignHeight="450" d:DesignWidth="600"
      Title="TestProgressBar">
    <Border BorderBrush="LightGray" Margin="20" Background="{StaticResource ThemeBackground}">
        <StackPanel>
            <Progress Width="40" Height="40" />
            <ProgressBarEXT Value="{Binding Value}" Minimum="-20" Maximum="50" Name="progress" SmallChange="0.2"/>
            <ProgressRound Value="{Binding Value}" Width="70" IDrag="True" Angle="280"/>
            <ProgressBoard Value="{Binding Value}" Width="70" />
        </StackPanel>
    </Border>
</Page>
