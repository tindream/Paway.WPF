<Page x:Class="Paway.Test.TestDataGrid"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Paway.Test"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
      mc:Ignorable="d" 
      UseLayoutRounding="True"
      DataContext="{Binding TestDataGrid, Source={StaticResource Locator}}"
      d:DesignHeight="450" d:DesignWidth="600"
      Title="TestDataGrid">
    <Page.Resources>
        <FrameworkElement x:Key="ProxyElement" DataContext="{Binding}"/>
    </Page.Resources>
    <Border x:Name="Root" BorderBrush="LightGray" Margin="20" Background="{StaticResource ThemeBackground}">
        <DockPanel>
            <!--只是将ProxyElement添加到树-->
            <ContentControl Content="{StaticResource ProxyElement}" Visibility="Collapsed"/>
            <DataPager DockPanel.Dock="Bottom" Name="dataPager" Margin="0,0,0,3" Source="{Binding PagedList}"/>
            <DataGridEXT ItemsSource="{Binding PagedList}" SelectionUnit="Cell" Name="datagrid1" BorderThickness="0" GridLinesVisibility="All" HorizontalContentAlignment="Center">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="CurrentCellChanged">
                        <i:InvokeCommandAction Command="{Binding CurrentCellCommand}" CommandParameter="{Binding ElementName=datagrid1}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <DataGridEXT.Columns>
                    <DataGridTemplateColumn Header="List" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ListViewCustom ItemsSource="{Binding List}" ItemWidthType="OneColumn" ClickMode="Press" SelectedValuePath="Id" SelectedValue="{Binding DataContext.IValue, RelativeSource={RelativeSource AncestorType={x:Type local:TestDataGrid}}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="IsSelected" Visibility="{Binding DataContext.IsSelected, Source={StaticResource ProxyElement}, Converter={StaticResource boolToVisible}}">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <CheckBoxEXT IsChecked="{Binding DataContext.IsSelected, RelativeSource={RelativeSource AncestorType={x:Type local:TestDataGrid}}}" Padding="10,6,4,6" Margin="-8,-10,-2,-10"/>
                                </DockPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <CheckBoxEXT IsChecked="{Binding IsPressed, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGridEXT.Columns>
            </DataGridEXT>
        </DockPanel>
    </Border>
</Page>
