<Page x:Class="Paway.Test.TestExpander"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Paway.Test"
      xmlns:model="clr-namespace:Paway.Model;assembly=Paway.Model"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
      mc:Ignorable="d" 
      UseLayoutRounding="True"
      DataContext="{Binding TestExpander, Source={StaticResource Locator}}"
      d:DesignHeight="450" d:DesignWidth="600"
      Title="TestExpander">
    <Border BorderBrush="LightGray" Margin="20" Background="{StaticResource ThemeBackground}">
        <DockPanel>
            <ExpanderEXT ExpandDirection="Left" DockPanel.Dock="Left" Header="Left">
                <Label Width="200"/>
            </ExpanderEXT>
            <ExpanderEXT ExpandDirection="Right" DockPanel.Dock="Right" Header="Right">
                <Label Width="200"/>
            </ExpanderEXT>
            <ExpanderEXT ExpandDirection="Up" DockPanel.Dock="Top" Header="Up">
                <Label Height="200"/>
            </ExpanderEXT>
            <ExpanderEXT ExpandDirection="Down" DockPanel.Dock="Bottom" Header="Down">
                <Label Height="200"/>
            </ExpanderEXT>
            <Border/>
        </DockPanel>
    </Border>
</Page>
